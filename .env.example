# =====================================================
# Excel Database Query Tool - 环境变量配置
# 复制此文件为 .env 并修改配置值
# =====================================================

# 安全密钥（生产环境务必修改！）
SECRET_KEY=excel-query-secret-key-change-me
JWT_SECRET_KEY=excel-query-jwt-secret-key-change-me
ENCRYPTION_KEY=your-encryption-key-32-bytes-long!

# 外部MySQL数据库连接（如果使用外部MySQL，在config.yaml中配置）
# 本项目默认使用SQLite（由ORM自动创建），如需MySQL请修改config.yaml中的database配置
